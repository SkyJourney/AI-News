---
// AInews · 顶栏
// 布局：Logo 左 · 搜索按钮 + 主题切换 右
// 视觉：透明背景，滚动时无边框（sticky 不 solid）
import Logo from './Logo.astro'
import GlassSearchBar from './GlassSearchBar.tsx'
---

<!-- Material Symbols Outlined 变量字体（放 head 靠 Astro 自动提升） -->
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
/>

<header class="lumina-header">
  <div class="lumina-header-inner">
    <div class="lumina-header-left">
      <Logo />
    </div>
    <nav class="lumina-header-right" aria-label="全局操作">
      <GlassSearchBar client:idle />
      <button class="lumina-header-btn" aria-label="切换主题（v2）">
        <span class="material-symbols-outlined">contrast</span>
      </button>
    </nav>
  </div>
</header>

<style>
  .lumina-header {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 0.75rem 0;
    background: transparent;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .lumina-header-inner {
    max-width: var(--lumina-container-max);
    margin-inline: auto;
    padding-inline: var(--lumina-margin-edge);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .lumina-header-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .lumina-header-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .lumina-header-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: transparent;
    border: none;
    border-radius: var(--radius-full);
    color: var(--color-darkgray);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .lumina-header-btn:hover {
    background: var(--surface-container-high);
    color: var(--color-dark);
  }

  @media (max-width: 768px) {
    .lumina-header-inner {
      padding-inline: 1rem;
    }
  }
</style>
