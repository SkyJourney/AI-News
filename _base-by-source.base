filters:
  or:
    - file.inFolder: "50-Zettel"
    - file.inFolder: "10-Daily"
    - file.inFolder: "20-Topics"

views:
  - name: 按 source 看条目
    type: table
    filters:
      - source != null
    order:
      - source ASC
      - created DESC
    columns:
      - file.name
      - source
      - topic
      - created
      - tags
  - name: 一手源（OpenAI/Anthropic/DeepMind）
    type: table
    filters:
      - source: ["openai-rss", "anthropic-news", "deepmind-rss"]
    order:
      - created DESC
    columns:
      - file.name
      - source
      - topic
      - created
  - name: 学术（arXiv + HF）
    type: table
    filters:
      - source: ["arxiv-api", "huggingface-daily-papers"]
    order:
      - created DESC
    columns:
      - file.name
      - source
      - topic
      - tags
  - name: 投资视角
    type: table
    filters:
      - source: ["air-street-press", "a16z-news-content", "state-of-ai"]
    order:
      - created DESC
    columns:
      - file.name
      - source
      - topic
