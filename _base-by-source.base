filters:
  or:
    - file.inFolder("50-Zettel")
    - file.inFolder("10-Daily")
    - file.inFolder("20-Topics")
views:
  - type: table
    name: 按 source 看条目
    filters:
      and:
        - source != null
    order:
      - source
      - created
      - file.name
      - topic
  - type: table
    name: 一手源（OpenAI/Anthropic/DeepMind）
    filters:
      and:
        - source == "openai-rss" || source == "anthropic-news" || source == "deepmind-rss"
    order:
      - created
      - file.name
      - source
      - topic
  - type: table
    name: 学术（arXiv + HF）
    filters:
      and:
        - source == "arxiv-api" || source == "huggingface-daily-papers"
    order:
      - created
      - file.name
      - source
      - topic
  - type: table
    name: 投资视角
    filters:
      and:
        - source == "air-street-press" || source == "a16z-news-content" || source == "state-of-ai"
    order:
      - created
      - file.name
      - source
      - topic
