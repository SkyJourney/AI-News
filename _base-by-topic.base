filters:
  and:
    - file.inFolder("50-Zettel")
views:
  - type: table
    name: 按主题分组
    order:
      - topic
      - created
      - file.name
      - source
      - status
  - type: table
    name: 高优 draft
    filters:
      and:
        - status == "draft"
    order:
      - created
      - file.name
      - topic
      - source
  - type: cards
    name: 卡片视图
    order:
      - created
      - file.name
      - topic
      - source
