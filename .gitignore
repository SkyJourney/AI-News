# Obsidian: 入库共享配置，忽略本机临时状态
.obsidian/*
!.obsidian/app.json
!.obsidian/appearance.json
!.obsidian/core-plugins.json
.obsidian/workspace*.json
.obsidian/cache/

# Obsidian 垃圾箱
.trash/
.obsidian/.trash/

# macOS 噪音
.DS_Store

# 本地实验 / 暂存
.scratch/
*.tmp

# Claude Code 临时文件（持久化文档另说，但 tool-results 不入库）
.claude/projects/

# /ai-news v2.4 per-source fetch 中转文件（保留作 debug 但不入 git；总 fetch.json/filtered.json/cluster.json 不在排除内）
00-Inbox/*-fetch-*.json

# Python 副产物
__pycache__/
*.pyc

# F2 前端站点构建产物（web/poc-* 与 web/ 通用）
web/*/node_modules/
web/*/dist/
web/*/public/
web/*/.cache/
web/*/.astro/
web/*/resources/_gen/
web/*/.hugo_build.lock
web/*/.git.upstream-orig/
# Quartz 5 插件解析缓存（含所有社区主题近 1G，`npm run install-plugins` 重生）
web/*/.quartz/

